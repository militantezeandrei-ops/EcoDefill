generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Represents both Students and Admin accounts.
/// Balance is stored in 'points' where 1 point typically equals 100ml.
model User {
  email           String           @unique @db.VarChar(255)
  fullName        String?
  passwordHash    String
  balance         Decimal          @default(0) @db.Decimal(10, 2)
  course          String?          @db.VarChar(50)
  yearLevel       String?          @db.VarChar(10)
  section         String?          @db.VarChar(10)
  createdAt       DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @db.Timestamptz(6)
  id              String           @id @default(uuid()) @db.Uuid
  hasSeenGuide    Boolean          @default(false)
  role            Role             @default(STUDENT)
  machineSessions MachineSession[]
  qrTokens        QrToken[]
  recyclingLogs   RecyclingLog[]
  transactions    Transaction[]

  @@index([email])
}

model VerificationCode {
  id        String    @id @default(uuid()) @db.Uuid
  email     String    @db.VarChar(255)
  codeHash  String
  purpose   String    @db.VarChar(30)
  expiresAt DateTime  @db.Timestamptz(6)
  used      Boolean   @default(false)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  usedAt    DateTime? @db.Timestamptz(6)

  @@index([email, purpose, expiresAt])
}

/// Records all point-related events (EARN from recycling, REDEEM for water).
model Transaction {
  type         String   @db.VarChar(20)
  amount       Decimal  @db.Decimal(10, 2)
  materialType String?  @db.VarChar(20)
  count        Int?
  status       String   @default("SUCCESS") @db.VarChar(20)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  id           String   @id @default(uuid()) @db.Uuid
  userId       String?  @db.Uuid
  user         User?    @relation(fields: [userId], references: [id])

  @@index([userId, type, createdAt])
}

/// Short-lived tokens for QR interactions. 
/// 'EARN' for recycling machine, 'REDEEM' for water dispenser.
model QrToken {
  token      String    @unique
  shortToken String?   @unique @db.VarChar(20)
  type       String    @default("EARN") @db.VarChar(20)
  amount     Decimal   @default(0) @db.Decimal(10, 2)
  expiresAt  DateTime  @db.Timestamptz(6)
  used       Boolean   @default(false)
  usedAt     DateTime? @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  user       User      @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([shortToken])
  @@index([userId, expiresAt])
}

/// Represents an active hardware interaction session (e.g., dispensing water).
/// Uses JTI for replay prevention.
model MachineSession {
  machineId        String   @db.VarChar(50)
  pointsToDeduct   Decimal  @db.Decimal(10, 2)
  amountToDispense Decimal  @db.Decimal(10, 2)
  status           String   @default("INITIATED") @db.VarChar(20)
  jti              String   @unique
  createdAt        DateTime @default(now()) @db.Timestamptz(6)
  expiresAt        DateTime @db.Timestamptz(6)
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  user             User     @relation(fields: [userId], references: [id])

  @@index([machineId, status])
  @@index([jti])
}

/// Detailed logs for items processed by the recycling machine.
/// userId is nullable to support walk-in / anonymous users (no mobile app).
model RecyclingLog {
  machineId      String   @db.VarChar(50)
  materialType   String   @db.VarChar(20)
  count          Int
  pointsEarned   Decimal  @db.Decimal(10, 2)
  status         String   @default("SUCCESS") @db.VarChar(20)
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  id             String   @id @default(uuid()) @db.Uuid
  userId         String?  @db.Uuid
  isWalkIn       Boolean  @default(false)
  waterDispensed Decimal? @db.Decimal(10, 2)
  user           User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([machineId, createdAt])
  @@index([isWalkIn, createdAt])
}

/// System-level logs for IoT hardware health monitoring.
model MachineLog {
  machineId String   @db.VarChar(50)
  status    String   @db.VarChar(20)
  message   String?
  pingMs    Int?
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  id        String   @id @default(uuid()) @db.Uuid

  @@index([machineId, createdAt])
}

enum Role {
  STUDENT
  ADMIN
}
